{
  "schema": "polar-bench-experiment/v1",
  "protocol": "string-like-prefix-lookup/v1",
  "experiment": "string-like-prefix-lookup",
  "title": "String LIKE prefix lookup",
  "research": "RQ-LOOKUP-STRING-LIKE-001",
  "hypothesis": "H-STRING-PREFIX-RANGE-COMPARATOR",
  "description": "Compare SQLite SQL LIKE with Polar.DB string prefix comparator/range traversal after load/build/reopen lifecycle.",
  "dataset": {
    "profile": "string-like-names-1m",
    "count": 1000000,
    "seed": 20260507
  },
  "workload": {
    "type": "string-like-prefix-lookup",
    "lookup": 30,
    "options": {
      "groupCount": "100",
      "subGroupCount": "100",
      "payloadBytes": "64",
      "warmupIterations": "5",
      "measuredIterations": "30",
      "includeContainsScan": "true",
      "pivotId": "742"
    }
  },
  "fairness": {
    "type": "lookup-prefix-balanced",
    "notes": "SQLite uses LIKE with case_sensitive_like=ON; Polar.DB uses SVectorIndex.GetAllByLike for prefix cases and scan only for containsScan."
  },
  "requires": [
    "BulkLoad",
    "RangeLookup",
    "ReopenRecovery",
    "PhysicalArtifactInspection"
  ],
  "targets": {
    "polar-db-current": { "engine": "polar-db" },
    "sqlite": { "engine": "sqlite" }
  },
  "runs": {
    "warmup": 1,
    "measured": 3,
    "notes": "Outer runs are process-level benchmark repetitions; workload.options controls inner LIKE query sampling."
  },
  "compare": {
    "history": true,
    "otherExperiments": true
  }
}
