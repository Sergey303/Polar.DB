{
  "schema": "polar-bench-experiment/v1",
  "protocol": "string-like-prefix-lookup/v1",
  "experiment": "string-like-contains-scan",
  "title": "String LIKE contains scan",
  "research": "RQ-LOOKUP-STRING-LIKE-001",
  "hypothesis": "H-STRING-CONTAINS-LEADING-WILDCARD-SCAN",
  "description": "Isolate the contains LIKE case. The leading-wildcard pattern is intentionally treated as scan-only, not as a prefix-index lookup.",
  "dataset": {
    "profile": "string-like-names-1m",
    "count": 1000000,
    "seed": 20260507
  },
  "workload": {
    "type": "string-like-prefix-lookup",
    "lookup": 30,
    "options": {
      "groupCount": "100",
      "subGroupCount": "100",
      "payloadBytes": "64",
      "warmupIterations": "5",
      "measuredIterations": "30",
      "includeContainsScan": "true",
      "searchMode": "contains-scan",
      "useNameIndex": "false",
      "pivotId": "742"
    }
  },
  "fairness": {
    "type": "lookup-contains-scan-baseline",
    "notes": "Contains case only. Pattern has a leading wildcard (%subXXXX%), so the fair baseline is scan. This experiment keeps it separate from prefix-index measurements."
  },
  "requires": [
    "BulkLoad",
    "ReopenRecovery",
    "PhysicalArtifactInspection"
  ],
  "targets": {
    "polar-db-current": { "engine": "polar-db" },
    "sqlite": { "engine": "sqlite" }
  },
  "runs": {
    "warmup": 1,
    "measured": 3,
    "notes": "Outer runs are process-level benchmark repetitions; workload.options controls inner LIKE query sampling."
  },
  "compare": {
    "history": true,
    "otherExperiments": true
  }
}
