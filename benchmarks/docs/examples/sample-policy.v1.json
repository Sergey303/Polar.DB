{
  "policy": "sample-policy-v1",
  "applies": {
    "experiment": "bulk-load-point-lookup",
    "dataset": "persons-100k-reverse",
    "engine": "synthetic",
    "fairness": "durability-balanced",
    "env": "local"
  },
  "guards": [
    {
      "metric": "elapsedMsSingleRun",
      "mode": "relative_to_baseline",
      "maxRegression": 15.0,
      "slack": 25.0,
      "severity": "Regressed"
    },
    {
      "metric": "totalArtifactBytes",
      "mode": "absolute_max",
      "max": 10000000.0,
      "severity": "Broken"
    }
  ]
}
